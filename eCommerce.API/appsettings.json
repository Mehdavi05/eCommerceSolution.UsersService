    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings":
  {
    "PostgresConnectionValuesHardcoded": "Host=localhost; Port=5432; Database=eCommerceUsers; Username=postgres; Password=admin",
